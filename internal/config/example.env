# =============================================================================
# Grok-Register 配置模板 (config.env.example)
# =============================================================================
# 本文件在每次 `grok start` / `grok config` 时会同步到:
#   ~/.grok/config.env.example
#
# 正式生效的配置请编辑:
#   ~/.grok/config.env
# 或运行: grok config
#
# 升级后请对照本文件，把新增项拷贝进 config.env 并按需填写。
# =============================================================================


# -----------------------------------------------------------------------------
# 0) 运行参数（不写进 config.env，请用命令行 / 交互）
# -----------------------------------------------------------------------------
# 注册数量 = 探活成功写入 CPA/ 的数量
#   grok start              → 启动后提示输入
#   grok start -t 10
#
# 并发线程 = Turnstile / 注册并行数 (1-8)
#   grok start              → 启动后提示输入 1-8
#   grok start --thread 3
#   grok start -j 3
#
# 组合示例:
#   grok start -t 20 --thread 4


# -----------------------------------------------------------------------------
# 1) 邮箱
# -----------------------------------------------------------------------------
# 模式:
#   tempmail  — 公共临时邮箱 (tempmail.lol，失败回退 mail.tm 系)，无需密钥
#   testmail  — testmail.app（如 GitHub Student Pack Essential）
#   custom    — 自建域名 + 本地 webhook（见 cloudflare/email-worker.js）
EMAIL_MODE=tempmail

# --- testmail.app（EMAIL_MODE=testmail 时必填）---
# 控制台: https://testmail.app/console
# 地址形态: {namespace}.{tag}@inbox.testmail.app （tag 程序自动随机）
# EMAIL_MODE=testmail
# TESTMAIL_API_KEY=
# TESTMAIL_NAMESPACE=
# TESTMAIL_DOMAIN=inbox.testmail.app

# --- 自建域名（EMAIL_MODE=custom 时必填）---
# EMAIL_MODE=custom
# EMAIL_DOMAIN=example.com
# EMAIL_API=http://127.0.0.1:8080


# -----------------------------------------------------------------------------
# 2) Cloudflare 清障栈（WARP + Privoxy + FlareSolverr）
# -----------------------------------------------------------------------------
# 需先: cd clearance && docker compose up -d
# 本机端口: 40080=Privoxy(HTTP)  8191=FlareSolverr  40000=WARP SOCKS5

# 是否启用 FlareSolverr 预热 cookies
CLEARANCE_ENABLED=1

# 注册 / 浏览器 mint 使用的 HTTP 代理（宿主机访问 Privoxy）
REGISTER_PROXY=http://127.0.0.1:40080

# FlareSolverr 管理地址（宿主机）
FLARESOLVERR_URL=http://127.0.0.1:8191

# FlareSolverr 容器内访问 Privoxy 的地址（compose 网络服务名）
CLEARANCE_PROXY=http://privoxy:8118

# 预热目标 URL 列表（逗号分隔）
CLEARANCE_URLS=https://accounts.x.ai,https://x.ai,https://status.x.ai,https://console.x.ai,https://auth.x.ai


# -----------------------------------------------------------------------------
# 3) Turnstile 验证码
# -----------------------------------------------------------------------------
# 提供方:
#   browser  — 默认；常驻 CloakBrowser 池并行 mint，回退 one-shot / chromedp
#   lite     — 外接 YesCaptcha 形 farm
#   chromedp — 仅 chromedp（CF 下通常较差）
TURNSTILE_PROVIDER=browser

# 外接 farm（TURNSTILE_PROVIDER=lite 时）
# TURNSTILE_PROVIDER=lite
# LITE_SOLVER_URL=http://127.0.0.1:5072

# 强制指定 Chromium 路径（一般可自动探测 ~/.cloakbrowser）
# CHROME_PATH=


# -----------------------------------------------------------------------------
# 4) 协议与临时邮箱限速
# -----------------------------------------------------------------------------
# 1=注册腿走 HTTP（推荐）；0=更多依赖浏览器
PROTOCOL_HTTP=1

# HTTP 连接池大小（协议客户端）
HTTP_POOL_SIZE=8

# tempmail.lol 创建失败重试次数
TEMPMAIL_LOL_RETRIES=30

# tempmail.lol 两次创建最小间隔（毫秒），减轻 429
TEMPMAIL_LOL_MIN_INTERVAL_MS=1500


# -----------------------------------------------------------------------------
# 5) 进程级 HTTP 代理（邮箱等出站请求）
# -----------------------------------------------------------------------------
# 一般与 REGISTER_PROXY 相同；留空则跟随系统环境
HTTPS_PROXY=http://127.0.0.1:40080
HTTP_PROXY=http://127.0.0.1:40080

# 不走代理的地址（本机 CPA / FlareSolverr 等）
NO_PROXY=127.0.0.1,localhost


# -----------------------------------------------------------------------------
# 6) 探活与高级并发
# -----------------------------------------------------------------------------
# 1=OAuth 后请求 cli-chat-proxy 探活，成功才写入 CPA/
PROBE_ENABLED=1

# 浏览器物理并发上限（高级）。0=跟随 start 时的 --thread
# PHYSICAL_CAP=0


# -----------------------------------------------------------------------------
# 7) CPA Management 自动 / 手动上传
# -----------------------------------------------------------------------------
# 宿主机上的 grok 必须用 127.0.0.1，不要写 docker 服务名（如 cli-proxy-api）
# 路径需包含 /v0/management（上传会再拼 /auth-files）
#
# 自动上传: CPA_UPLOAD_ENABLED=1 且填写 KEY
# 手动上传: grok upload

# 是否在 CPA 成功后自动上传
CPA_UPLOAD_ENABLED=0

# Management API 根路径
CPA_MANAGEMENT_BASE=http://127.0.0.1:8317/v0/management

# 管理密钥（勿提交仓库；日志不会打印）
CPA_MANAGEMENT_KEY=

# 单次上传超时（秒）
CPA_UPLOAD_TIMEOUT_SEC=30

# 失败重试次数
CPA_UPLOAD_RETRIES=2

# 上传文件名模板，可用 {email} {provider} {sub}
CPA_UPLOAD_NAME_TEMPLATE={email}.json

# 上传后是否 GET 列表校验
CPA_UPLOAD_VERIFY=1

# 上传方式: multipart（推荐）| json
CPA_UPLOAD_MODE=multipart
