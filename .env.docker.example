# Copy this file to .env before running docker compose.

# Build
GO_VERSION=1.26.5
TZ=Asia/Shanghai

# Default target shown by the Web console. It can still be changed for each run.
GROK_TARGET=10

# Web management console.
WEB_ENABLED=1
WEB_PORT=8090
WEB_USERNAME=admin
WEB_PASSWORD=change-this-password

# Email mode: tempmail needs no extra config. custom needs EMAIL_DOMAIN and EMAIL_API.
EMAIL_MODE=tempmail
EMAIL_DOMAIN=
EMAIL_API=http://127.0.0.1:8080
TESTMAIL_API_KEY=
TESTMAIL_NAMESPACE=
TESTMAIL_DOMAIN=inbox.testmail.app

# Clearance/proxy stack. The defaults are for Docker Compose service names.
CLEARANCE_ENABLED=1
CLEARANCE_MODE=auto
CLEARANCE_AUTO_STOP=0
CF_IMPERSONATE=chrome_131
CF_IMPERSONATE_FALLBACK=chrome_124,chrome_120
REGISTER_PROXY=http://privoxy:8118
FLARESOLVERR_URL=http://flaresolverr:8191
CLEARANCE_PROXY=http://privoxy:8118
CLEARANCE_URLS=https://accounts.x.ai,https://x.ai,https://status.x.ai,https://console.x.ai,https://auth.x.ai

# Turnstile. browser uses the bundled Playwright + CloakBrowser path.
TURNSTILE_PROVIDER=browser
TURNSTILE_MODE=offscreen
LITE_SOLVER_URL=http://127.0.0.1:5072
# Optional path inside the container. Leave empty to use automatic discovery.
CHROME_PATH=

# Throughput and retry knobs.
PROTOCOL_HTTP=1
HTTP_POOL_SIZE=8
TEMPMAIL_LOL_RETRIES=30
TEMPMAIL_LOL_MIN_INTERVAL_MS=1500
OAUTH_MIN_INTERVAL_SEC=6
OAUTH_RETRY_SEC=60
OAUTH_WORKERS=0
PROBE_ENABLED=1
PROBE_WARMUP_SEC=5
OUTPUT_SSO_ENABLED=1
OUTPUT_GROK2API_SSO_ENABLED=1
# CPA output is the prerequisite for OAuth/probe/auto upload.
OUTPUT_CPA_ENABLED=1
PHYSICAL_CAP=0
# Web/Docker convenience: passed as grok start -j when launching from Web. CLI does not Load this key.
TURNSTILE_WORKERS=2

# Container outbound proxy. Keep these on privoxy unless you know you want direct egress.
HTTP_PROXY=http://privoxy:8118
HTTPS_PROXY=http://privoxy:8118
NO_PROXY=127.0.0.1,localhost,privoxy,flaresolverr,warp-proxy

# Optional CPA Management upload.
CPA_UPLOAD_ENABLED=0
CPA_MANAGEMENT_BASE=http://host.docker.internal:8317/v0/management
CPA_MANAGEMENT_KEY=
CPA_UPLOAD_TIMEOUT_SEC=30
CPA_UPLOAD_RETRIES=2
CPA_UPLOAD_NAME_TEMPLATE={email}
CPA_UPLOAD_VERIFY=1
CPA_UPLOAD_MODE=multipart

# Root one-shot stack publishes ONLY the Web console (see WEB_PORT above).
# Clearance services stay on the compose network and are not mapped to the host.
# For a host-side clearance stack, use clearance/docker-compose.yml
# (WARP_SOCKS_PORT / PRIVOXY_PORT / FLARESOLVERR_PORT live there).

# Optional Cloudflare WARP+ license.
WARP_LICENSE_KEY=
